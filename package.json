{
  "name": "@wpengine/hwp-toolkit",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "clean": "bash ./scripts/clean.sh",
    "dev": "bash ./scripts/dev.sh",
    "stop": "pnpm --filter '*' stop",
    "release": "npm run build && changeset publish",
    "changeset": "changeset",
    "reformat:md": "remark --rc-path .remarkrc.json --output --"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=10"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.7",
    "@playwright/test": "^1.56.1",
    "@wordpress/e2e-test-utils-playwright": "^1.31.0",
    "@wordpress/env": "^10.39.0",
    "@wordpress/jest-console": "^8.31.0",
    "@wordpress/scripts": "30.26.2",
    "js-yaml": "^4.1.1",
    "remark-gfm": "^4.0.1",
    "rimraf": "^5.0.5"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "markdownlint-cli>minimatch": "3.1.4",
      "@typescript-eslint/typescript-estree>minimatch": "9.0.7",
      "serialize-javascript": "7.0.5",
      "webpack-dev-server": "5.2.3",
      "ajv": "8.18.0",
      "@tootallnate/once": "3.0.1",
      "tmp": "0.2.5"
    }
  },
  "dependencies": {
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-preset-lint-recommended": "^7.0.1"
  }
}
